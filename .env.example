# ============================================================
# QQ Agent Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Bot Identity ---
BOT_QQ=123456789
OWNER_QQ=987654321
OWNER_QQS=987654321,123456789
OWNER_NAME=YourName

# --- NapCat Connection ---
NAPCAT_WS_URL=ws://127.0.0.1:3001  # NapCat OneBot WebSocket URL

# --- OpenClaw Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789
GATEWAY_TOKEN=your_gateway_token

# --- HTTP Callback ---
CALLBACK_HOST=127.0.0.1
CALLBACK_PORT=19283

# --- Monitored Groups ---
MONITORED_GROUPS=123456789,987654321
GROUP_NAMES={"123456789":"Group A","987654321":"Group B"}

# --- Intent Classifier (LLM API) ---
INTENT_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
INTENT_API_KEY=your_intent_api_key
INTENT_MODEL=qwen-plus

# --- Quick Reply Model ---
QUICK_API_URL=https://api.example.com/v1/chat/completions
QUICK_API_KEY=your_quick_api_key
QUICK_MODEL=your-model-name

# --- Feedback Monitor (Python scripts) ---
LLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_KEY=your_llm_api_key
LLM_MODEL=qwen-plus

# --- Data Directories ---
DATA_DIR=/data
WORKSPACE_DIR=/data/workspace

# --- Runtime Integration ---
RUNTIME_USER=openclaw
OPENCLAW_LOG_DIR=/tmp/openclaw

# --- Bot Personality ---
BOT_NAME=小助手
BOT_PERSONA=你是一个友好的QQ群助手

# --- Node.js Path (for Python scripts calling node) ---
NODE_BIN=/usr/bin/node
